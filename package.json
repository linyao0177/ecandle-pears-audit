{
  "name": "ecandle-pears-audit",
  "version": "0.0.2",
  "description": "Peer-to-peer audit viewer for eCandle DePIN device feeds — Hypercore + Hyperswarm replication, Pear-runtime desktop app.",
  "type": "module",
  "pear": {
    "name": "ecandle-pears-audit",
    "type": "desktop",
    "pre": "pear-electron/pre",
    "gui": {
      "main": "ui/index.html",
      "backgroundColor": "#0a0a0a",
      "width": 980,
      "height": 760
    }
  },
  "bin": {
    "ecandle-audit": "bin/audit-cli.js"
  },
  "scripts": {
    "smoke": "node bin/audit-cli.js",
    "dev": "pear run --dev .",
    "stage": "pear stage current ."
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "linyao0177",
  "repository": {
    "type": "git",
    "url": "https://github.com/linyao0177/ecandle-pears-audit"
  },
  "keywords": [
    "ecandle",
    "depin",
    "audit",
    "hypercore",
    "hyperswarm",
    "pear",
    "holepunch",
    "tether"
  ],
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "b4a": "^1.6.6",
    "corestore": "^7.0.0",
    "hypercore": "^11.0.0",
    "hyperswarm": "^4.7.0",
    "pear-bridge": "^1.2.5",
    "pear-electron": "^1.7.28",
    "random-access-memory": "^6.2.1"
  },
  "devDependencies": {
    "pear": "^2.0.1"
  }
}
